# Wix Headless OAuth client ID (server-only use; set in Vercel)
WIX_CLIENT_ID_HEADLESS=your-wix-headless-oauth-client-id

# Wix Backend API key (server-only — never expose to client)
WIX_BACKEND_KEY=your-wix-backend-api-key

# Velo site base URL for HTTP functions (no trailing slash)
WIX_VELO_SITE_URL=https://www.carolinafutons.com

# HMAC shared secret for Wix CMS webhook -> /api/revalidate
# Same value must be configured on the Wix side that signs the webhook body.
WIX_WEBHOOK_SECRET=your-wix-webhook-hmac-shared-secret

# Sentry DSNs (optional — no DSN = no-op init; leave unset in dev/preview).
# SENTRY_DSN is server-side; NEXT_PUBLIC_SENTRY_DSN is client-side.
# Both are the same DSN in practice; split only if you want to silence client reports.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Google Search Console site verification token (the value from the meta-tag
# verification option in GSC — not the full tag, just the content= string).
# Set in Vercel before the cf-3qt.8 DNS cutover, then submit the sitemap at
# https://search.google.com/search-console after DNS propagates.
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification token (value from the msvalidate.01 meta tag).
# Set in Vercel alongside GOOGLE_SITE_VERIFICATION; submit sitemap at
# https://www.bing.com/webmasters after DNS propagates.
BING_SITE_VERIFICATION=

# Canonical site URL — used for OG metadata, sitemap, and checkout callback URLs.
# Set to the Vercel production URL (no trailing slash). Falls back to request
# headers in development and on preview deploys where this may differ.
NEXT_PUBLIC_SITE_URL=https://carolinafutons.com

# ── Analytics (cf-3qt.7) ─────────────────────────────────────────────────────
# All four tags no-op gracefully when their env var is absent — safe to leave
# unset in local dev. Set in Vercel project → Environment Variables for Preview
# and Production environments before the cf-3qt.8 DNS cutover.

# Google Analytics 4 measurement ID (direct gtag.js; NOT via GTM container).
# Find in GA4 → Admin → Data Streams → Web stream details.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-E88HTNX5RJ

# Meta (Facebook) Pixel ID — numeric string, 10–20 digits.
# Find in Meta Events Manager → Pixels → your pixel → Settings.
NEXT_PUBLIC_META_PIXEL_ID=314889864231730

# TikTok Pixel ID — alphanumeric, typically ~20 chars (e.g. C4A7ABCDE12345678).
# Find in TikTok Ads Manager → Assets → Events → Web Events → your pixel.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Pinterest Tag ID — numeric string (e.g. 2613486123456789).
# Find in Pinterest Ads → Conversions → Pinterest tag → your tag.
NEXT_PUBLIC_PINTEREST_TAG_ID=

# ── Fixture product mode ──────────────────────────────────────────────────────
# Swaps the live Wix catalog with 5 hand-curated fixture products for E2E
# cart/checkout/shipping QA on Vercel preview builds.
# NEVER set this to "1" in production or staging environments.
# Set via Vercel project settings → Environment Variables → Preview only.
NEXT_PUBLIC_USE_FIXTURE_PRODUCTS=
